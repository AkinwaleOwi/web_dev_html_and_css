
//beginning of calling in our buttons
const trueBtn = document.getElementById("trueBtn");
const falseBtn = document.getElementById("falseBtn");
//end of calling in our buttons

//beginning of true button inner workings
trueBtn.addEventListener("click", () => {
  trueBtn.classList.add("selected");
  falseBtn.classList.remove("selected");
});
//end of true button inner workings

//beginning of false button inner workings
falseBtn.addEventListener("click", () => {
  falseBtn.classList.add("selected");
  trueBtn.classList.remove("selected");
});
//end of false button inner workings
